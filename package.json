{
  "name": "template-engine-monorepo",
  "version": "1.0.0",
  "description": "TypeScript monorepo with apps backend and web",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/web"
  ],
  "scripts": {
    "prepare": "husky install",
    "dev": "npm run dev -ws --if-present",
    "build": "npm run build -ws --if-present",
    "clean": "npm run clean -ws --if-present",
    "compile": "npm run compile -ws --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --config .prettierrc '**/*.+(ts|tsx)'",
    "format:check": "prettier --config .prettierrc '**/*.+(ts|tsx)' --check",
    "format:fix": "prettier --config .prettierrc '**/*.+(ts|tsx|css|json|md)' --write",
    "test": "npm test -ws --if-present",
    "validate": "npm run compile && npm run lint && npm run test"
  },
  "author": "Softwarecrafters.io",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "lint-staged": "16.2.7",
    "npm-check-updates": "19.1.2",
    "prettier": "3.7.4",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
